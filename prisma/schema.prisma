generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}
model User {
  id        Int                @id @default(autoincrement())
  email     String             @unique
  password  String
  name      String?
  assets    Asset[]
  history   PortfolioHistory[]
  createdAt DateTime           @default(now())
}

model Asset {
  id            Int           @id @default(autoincrement())
  name          String
  symbol        String
  amount        Float         // Current total quantity owned
  purchasePrice Float         @default(0)
  category      String
  userId        Int
  user          User          @relation(fields: [userId], references: [id])


  // One asset has MANY transactions.
  transactions  Transaction[]

  lastPrice     Float?        @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([userId, symbol])
}

model PortfolioHistory {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  date       DateTime @default(now())
  totalValue Float

  @@unique([userId, date])
}

model Transaction {
  id        Int      @id @default(autoincrement())
  assetId   Int
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  type      String   // "BUY" or "SELL"
  amount    Float    // Total dollar value of this specific trade
  shares    Float    // Number of units moved in this specific trade
  createdAt DateTime @default(now())
}